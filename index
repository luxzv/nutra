<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="theme-color" content="#0a0a0f" />
  <title>Nutra</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/recharts/2.12.7/Recharts.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.5/babel.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #0a0a0f; color: #e8e8f0; height: 100%; }
    body { -webkit-font-smoothing: antialiased; overscroll-behavior: none; }
    input, textarea, button { font-family: 'DM Mono', monospace; }
    ::-webkit-scrollbar { width: 0; }
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useCallback } = React;
    const {
      LineChart, Line, BarChart, Bar,
      XAxis, YAxis, CartesianGrid, Tooltip,
      ResponsiveContainer, Legend
    } = Recharts;

    const DB_KEY = "nutra_v1";
    const load = () => { try { const r = localStorage.getItem(DB_KEY); return r ? JSON.parse(r) : null; } catch { return null; } };
    const save = (d) => { try { localStorage.setItem(DB_KEY, JSON.stringify(d)); } catch {} };
    const todayKey = () => new Date().toISOString().slice(0, 10);

    const defaultProfile = {
      name: "", age: "", height: "", weight: "",
      goalCalories: 2500, goalProtein: 195, goalCarbs: 200, goalFat: 80,
      protocol: "",
    };
    const defaultDay = () => ({
      date: todayKey(), calories: 0, protein: 0, carbs: 0, fat: 0,
      fiber: 0, sodium: 0, water: 0, weight: "", foods: [],
    });
    const emptyFood = { name: "", calories: "", protein: "", carbs: "", fat: "", fiber: "", sodium: "" };

    const TABS = ["Log", "Profile", "Progress"];

    const LogIcon = () => React.createElement("svg", { viewBox:"0 0 24 24", fill:"none", stroke:"currentColor", strokeWidth:2, width:20, height:20 },
      React.createElement("rect", { x:"3", y:"3", width:"18", height:"18", rx:"3" }),
      React.createElement("line", { x1:"8", y1:"9", x2:"16", y2:"9" }),
      React.createElement("line", { x1:"8", y1:"13", x2:"16", y2:"13" }),
      React.createElement("line", { x1:"8", y1:"17", x2:"12", y2:"17" })
    );
    const ProfileIcon = () => React.createElement("svg", { viewBox:"0 0 24 24", fill:"none", stroke:"currentColor", strokeWidth:2, width:20, height:20 },
      React.createElement("circle", { cx:"12", cy:"8", r:"4" }),
      React.createElement("path", { d:"M4 20c0-4 3.6-7 8-7s8 3 8 7" })
    );
    const ProgressIcon = () => React.createElement("svg", { viewBox:"0 0 24 24", fill:"none", stroke:"currentColor", strokeWidth:2, width:20, height:20 },
      React.createElement("polyline", { points:"3,17 8,11 13,14 21,6" }),
      React.createElement("line", { x1:"3", y1:"21", x2:"21", y2:"21" })
    );
    const NAV_ICONS = { Log: LogIcon, Profile: ProfileIcon, Progress: ProgressIcon };

    function MacroRing({ label, value, goal, color }) {
      const pct = Math.min((value / (goal || 1)) * 100, 100);
      const r = 28, circ = 2 * Math.PI * r;
      const dash = (pct / 100) * circ;
      return (
        <div style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:4 }}>
          <svg width={72} height={72} viewBox="0 0 72 72">
            <circle cx={36} cy={36} r={r} fill="none" stroke="#1a1a2e" strokeWidth={7}/>
            <circle cx={36} cy={36} r={r} fill="none" stroke={color} strokeWidth={7}
              strokeDasharray={`${dash} ${circ - dash}`} strokeLinecap="round"
              transform="rotate(-90 36 36)" style={{ transition:"stroke-dasharray 0.5s ease" }}/>
            <text x={36} y={40} textAnchor="middle" fill="#fff" fontSize={13}
              fontFamily="'DM Mono', monospace" fontWeight="600">{value}</text>
          </svg>
          <span style={{ color:"#8888aa", fontSize:11, letterSpacing:1 }}>{label}</span>
          <span style={{ color, fontSize:10 }}>{goal}g goal</span>
        </div>
      );
    }

    function WaterTracker({ value, onChange }) {
      const cups = 10;
      return (
        <div style={{ display:"flex", gap:6, flexWrap:"wrap", alignItems:"center" }}>
          {Array.from({ length: cups }).map((_, i) => (
            <button key={i} onClick={() => onChange(i < value ? i : i + 1)}
              style={{ width:28, height:36, border:"none", borderRadius:4, cursor:"pointer",
                background: i < value ? "#2563eb" : "#1a1a2e", transition:"background 0.2s" }}>
              <svg viewBox="0 0 20 28" width={14} height={20} style={{ display:"block", margin:"auto" }}>
                <path d="M10 2 L17 14 A7 7 0 1 1 3 14 Z" fill={i < value ? "#fff" : "#333355"}/>
              </svg>
            </button>
          ))}
          <span style={{ color:"#8888aa", fontSize:12, marginLeft:4 }}>{value * 8}oz / {cups * 8}oz</span>
        </div>
      );
    }

    function Nutra() {
      const [tab, setTab] = useState("Log");
      const [profile, setProfile] = useState(defaultProfile);
      const [days, setDays] = useState({});
      const [todayLog, setTodayLog] = useState(defaultDay());
      const [addingFood, setAddingFood] = useState(false);
      const [foodForm, setFoodForm] = useState(emptyFood);
      const [editingGoals, setEditingGoals] = useState(false);
      const [goalDraft, setGoalDraft] = useState({});

      useEffect(() => {
        const saved = load();
        if (saved) {
          if (saved.profile) setProfile(saved.profile);
          if (saved.days) {
            setDays(saved.days);
            setTodayLog(saved.days[todayKey()] || defaultDay());
          }
        }
      }, []);

      const persist = (newDays, newProfile) => {
        save({ profile: newProfile !== undefined ? newProfile : profile, days: newDays !== undefined ? newDays : days });
      };

      const updateToday = (updates) => {
        const updated = { ...todayLog, ...updates };
        setTodayLog(updated);
        const nd = { ...days, [todayKey()]: updated };
        setDays(nd);
        persist(nd);
      };

      const addFood = () => {
        if (!foodForm.name) return;
        const food = { name:foodForm.name, calories:Number(foodForm.calories)||0, protein:Number(foodForm.protein)||0,
          carbs:Number(foodForm.carbs)||0, fat:Number(foodForm.fat)||0, fiber:Number(foodForm.fiber)||0, sodium:Number(foodForm.sodium)||0 };
        const nf = [...todayLog.foods, food];
        const tot = nf.reduce((a,f) => ({ calories:a.calories+f.calories, protein:a.protein+f.protein,
          carbs:a.carbs+f.carbs, fat:a.fat+f.fat, fiber:a.fiber+f.fiber, sodium:a.sodium+f.sodium }),
          { calories:0, protein:0, carbs:0, fat:0, fiber:0, sodium:0 });
        updateToday({ foods:nf, ...tot });
        setFoodForm(emptyFood); setAddingFood(false);
      };

      const removeFood = (idx) => {
        const nf = todayLog.foods.filter((_,i) => i !== idx);
        const tot = nf.reduce((a,f) => ({ calories:a.calories+f.calories, protein:a.protein+f.protein,
          carbs:a.carbs+f.carbs, fat:a.fat+f.fat, fiber:a.fiber+f.fiber, sodium:a.sodium+f.sodium }),
          { calories:0, protein:0, carbs:0, fat:0, fiber:0, sodium:0 });
        updateToday({ foods:nf, ...tot });
      };

      const saveProfile = (p) => { setProfile(p); persist(undefined, p); };
      const saveGoals = () => { const u = { ...profile, ...goalDraft }; saveProfile(u); setEditingGoals(false); };

      const last7 = Array.from({ length:7 }).map((_,i) => {
        const d = new Date(); d.setDate(d.getDate() - (6-i));
        const key = d.toISOString().slice(0,10);
        const day = days[key] || {};
        return { label: d.toLocaleDateString("en-US", { weekday:"short" }),
          calories:day.calories||0, protein:day.protein||0, carbs:day.carbs||0,
          fat:day.fat||0, weight:day.weight ? Number(day.weight) : null };
      });

      const calRemain = profile.goalCalories - todayLog.calories;
      const dateLabel = new Date().toLocaleDateString("en-US", { weekday:"long", month:"long", day:"numeric" });

      const S = {
        app: { background:"#0a0a0f", minHeight:"100vh", maxWidth:430, margin:"0 auto",
          fontFamily:"'DM Mono', monospace", color:"#e8e8f0", paddingBottom:80 },
        header: { padding:"20px 20px 12px", borderBottom:"1px solid #1a1a2e", background:"#0a0a0f",
          position:"sticky", top:0, zIndex:10 },
        logo: { fontFamily:"'Syne', sans-serif", fontSize:28, fontWeight:800,
          background:"linear-gradient(135deg, #2563eb, #60a5fa)",
          WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent", letterSpacing:-1 },
        section: { margin:"16px 16px 0", background:"#0f0f1a", borderRadius:16,
          padding:16, border:"1px solid #1a1a2e" },
        secTitle: { fontSize:10, letterSpacing:2, color:"#4444aa", textTransform:"uppercase",
          marginBottom:12, fontWeight:500 },
        input: { background:"#0a0a0f", border:"1px solid #1a1a2e", borderRadius:8,
          color:"#e8e8f0", padding:"10px 12px", fontSize:13,
          fontFamily:"'DM Mono', monospace", width:"100%", outline:"none" },
        btn: { background:"#2563eb", border:"none", borderRadius:10, color:"#fff",
          padding:"12px 20px", fontSize:13, fontFamily:"'DM Mono', monospace",
          cursor:"pointer", fontWeight:500, letterSpacing:0.5 },
        btnGhost: { background:"transparent", border:"1px solid #1a1a2e", borderRadius:10,
          color:"#8888aa", padding:"10px 16px", fontSize:12,
          fontFamily:"'DM Mono', monospace", cursor:"pointer" },
        nav: { position:"fixed", bottom:0, left:"50%", transform:"translateX(-50%)",
          width:"100%", maxWidth:430, background:"#0a0a0f",
          borderTop:"1px solid #1a1a2e", display:"flex",
          justifyContent:"space-around", padding:"10px 0 24px", zIndex:20 },
        navBtn: (active) => ({ display:"flex", flexDirection:"column", alignItems:"center", gap:4,
          background:"transparent", border:"none", cursor:"pointer",
          color: active ? "#2563eb" : "#444466", fontSize:10,
          fontFamily:"'DM Mono', monospace", letterSpacing:1, padding:"4px 20px",
          transition:"color 0.2s" }),
        bar: (pct, color) => ({ height:6, borderRadius:3,
          background:`linear-gradient(90deg, ${color} ${Math.min(pct,100)}%, #1a1a2e ${Math.min(pct,100)}%)`,
          transition:"background 0.5s ease", marginTop:4 }),
        row: { display:"flex", justifyContent:"space-between", fontSize:12,
          color:"#8888aa", padding:"4px 0" },
        foodRow: { display:"flex", justifyContent:"space-between", alignItems:"center",
          padding:"10px 0", borderBottom:"1px solid #111122" },
      };

      const ttStyle = { contentStyle:{ background:"#0f0f1a", border:"1px solid #1a1a2e",
        borderRadius:8, fontFamily:"'DM Mono', monospace", fontSize:11 } };

      return (
        <div style={S.app}>
          <div style={S.header}>
            <div style={S.logo}>Nutra</div>
            <div style={{ color:"#555577", fontSize:11, letterSpacing:1, marginTop:2 }}>
              {dateLabel.toUpperCase()}
            </div>
          </div>

          {/* ── LOG TAB ── */}
          {tab === "Log" && (
            <div>
              {/* Calories */}
              <div style={S.section}>
                <div style={S.secTitle}>Calories</div>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-end" }}>
                  <div>
                    <div style={{ display:"flex", alignItems:"baseline", gap:6 }}>
                      <span style={{ fontFamily:"'Syne', sans-serif", fontSize:48, fontWeight:800,
                        lineHeight:1, color: calRemain >= 0 ? "#60a5fa" : "#f87171" }}>
                        {Math.abs(calRemain)}
                      </span>
                      <span style={{ color:"#555577", fontSize:12 }}>{calRemain >= 0 ? "remaining" : "over"}</span>
                    </div>
                    <div style={{ color:"#555577", fontSize:11, marginTop:6 }}>
                      {todayLog.calories} eaten · {profile.goalCalories} goal
                    </div>
                  </div>
                </div>
                <div style={S.bar((todayLog.calories / profile.goalCalories) * 100, calRemain >= 0 ? "#2563eb" : "#ef4444")} />
              </div>

              {/* Macros */}
              <div style={S.section}>
                <div style={S.secTitle}>Macros</div>
                <div style={{ display:"flex", justifyContent:"space-around" }}>
                  <MacroRing label="PROTEIN" value={todayLog.protein} goal={profile.goalProtein} color="#3b82f6"/>
                  <MacroRing label="CARBS" value={todayLog.carbs} goal={profile.goalCarbs} color="#8b5cf6"/>
                  <MacroRing label="FAT" value={todayLog.fat} goal={profile.goalFat} color="#f59e0b"/>
                </div>
              </div>

              {/* Micros + Water */}
              <div style={S.section}>
                <div style={S.secTitle}>Micros & Hydration</div>
                <div style={S.row}><span>Fiber</span><span style={{ color:"#e8e8f0" }}>{todayLog.fiber}g</span></div>
                <div style={S.row}><span>Sodium</span><span style={{ color:"#e8e8f0" }}>{todayLog.sodium}mg</span></div>
                <div style={{ marginTop:14 }}>
                  <div style={{ fontSize:11, color:"#555577", marginBottom:8, letterSpacing:1 }}>WATER (cups)</div>
                  <WaterTracker value={todayLog.water} onChange={(v) => updateToday({ water:v })}/>
                </div>
              </div>

              {/* Weight */}
              <div style={S.section}>
                <div style={S.secTitle}>Today's Weight</div>
                <input style={S.input} type="number" placeholder="Enter weight (lbs)"
                  value={todayLog.weight} onChange={e => updateToday({ weight:e.target.value })}/>
              </div>

              {/* Food log */}
              <div style={S.section}>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
                  <div style={S.secTitle}>Food Log</div>
                  <button style={S.btn} onClick={() => setAddingFood(true)}>+ Add</button>
                </div>
                {todayLog.foods.length === 0 && (
                  <div style={{ color:"#333355", fontSize:12, textAlign:"center", padding:"16px 0" }}>
                    No foods logged yet
                  </div>
                )}
                {todayLog.foods.map((f,i) => (
                  <div key={i} style={S.foodRow}>
                    <div>
                      <div style={{ fontSize:13, color:"#e8e8f0" }}>{f.name}</div>
                      <div style={{ fontSize:11, color:"#555577", marginTop:3 }}>
                        P {f.protein}g · C {f.carbs}g · F {f.fat}g{f.sodium ? ` · Na ${f.sodium}mg` : ""}
                      </div>
                    </div>
                    <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                      <span style={{ color:"#60a5fa", fontSize:14, fontWeight:600 }}>{f.calories}</span>
                      <button onClick={() => removeFood(i)}
                        style={{ background:"transparent", border:"none", color:"#333355", cursor:"pointer", fontSize:16, padding:4 }}>✕</button>
                    </div>
                  </div>
                ))}
                {addingFood && (
                  <div style={{ marginTop:16, display:"flex", flexDirection:"column", gap:8 }}>
                    <div style={{ fontSize:11, color:"#4444aa", letterSpacing:2, marginBottom:4 }}>ADD FOOD</div>
                    {[["Food name","name","text"],["Calories","calories","number"],
                      ["Protein (g)","protein","number"],["Carbs (g)","carbs","number"],
                      ["Fat (g)","fat","number"],["Fiber (g)","fiber","number"],["Sodium (mg)","sodium","number"]
                    ].map(([ph,key,type]) => (
                      <input key={key} style={S.input} type={type} placeholder={ph}
                        value={foodForm[key]}
                        onChange={e => setFoodForm(f => ({ ...f, [key]:e.target.value }))}/>
                    ))}
                    <div style={{ display:"flex", gap:8, marginTop:4 }}>
                      <button style={{ ...S.btn, flex:1 }} onClick={addFood}>Save</button>
                      <button style={{ ...S.btnGhost, flex:1 }}
                        onClick={() => { setAddingFood(false); setFoodForm(emptyFood); }}>Cancel</button>
                    </div>
                  </div>
                )}
              </div>

              {profile.protocol && (
                <div style={S.section}>
                  <div style={S.secTitle}>Current Protocol</div>
                  <div style={{ fontSize:12, color:"#8888aa", lineHeight:1.7, whiteSpace:"pre-wrap" }}>
                    {profile.protocol}
                  </div>
                </div>
              )}
            </div>
          )}

          {/* ── PROFILE TAB ── */}
          {tab === "Profile" && (
            <div>
              <div style={S.section}>
                <div style={S.secTitle}>Personal Info</div>
                <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
                  {[["Name","name","text"],["Age","age","number"],["Height (in)","height","text"],["Weight (lbs)","weight","number"]
                  ].map(([ph,key,type]) => (
                    <input key={key} style={S.input} type={type} placeholder={ph} value={profile[key]}
                      onChange={e => saveProfile({ ...profile, [key]:e.target.value })}/>
                  ))}
                </div>
              </div>

              <div style={S.section}>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
                  <div style={S.secTitle}>Goals</div>
                  {!editingGoals
                    ? <button style={S.btnGhost} onClick={() => {
                        setGoalDraft({ goalCalories:profile.goalCalories, goalProtein:profile.goalProtein,
                          goalCarbs:profile.goalCarbs, goalFat:profile.goalFat });
                        setEditingGoals(true);
                      }}>Edit</button>
                    : <button style={S.btn} onClick={saveGoals}>Save</button>
                  }
                </div>
                {editingGoals ? (
                  <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
                    {[["Calorie Goal","goalCalories"],["Protein Goal (g)","goalProtein"],
                      ["Carbs Goal (g)","goalCarbs"],["Fat Goal (g)","goalFat"]
                    ].map(([ph,key]) => (
                      <input key={key} style={S.input} type="number" placeholder={ph} value={goalDraft[key]}
                        onChange={e => setGoalDraft(d => ({ ...d, [key]:Number(e.target.value) }))}/>
                    ))}
                  </div>
                ) : (
                  <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
                    {[["Calories",profile.goalCalories,"kcal","#60a5fa"],
                      ["Protein",profile.goalProtein,"g","#3b82f6"],
                      ["Carbs",profile.goalCarbs,"g","#8b5cf6"],
                      ["Fat",profile.goalFat,"g","#f59e0b"]
                    ].map(([label,val,unit,color]) => (
                      <div key={label} style={{ display:"flex", justifyContent:"space-between" }}>
                        <span style={{ fontSize:12, color:"#8888aa" }}>{label}</span>
                        <span style={{ fontSize:12, color }}>{val}{unit}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>

              <div style={S.section}>
                <div style={S.secTitle}>Protocol / Notes</div>
                <textarea style={{ ...S.input, minHeight:120, resize:"vertical" }}
                  placeholder="e.g. Enclomiphene 12.5mg/day, cutting phase, 5x/week training..."
                  value={profile.protocol}
                  onChange={e => saveProfile({ ...profile, protocol:e.target.value })}/>
              </div>
            </div>
          )}

          {/* ── PROGRESS TAB ── */}
          {tab === "Progress" && (
            <div>
              <div style={S.section}>
                <div style={S.secTitle}>Macros — Last 7 Days</div>
                <ResponsiveContainer width="100%" height={200}>
                  <BarChart data={last7} margin={{ top:4, right:4, left:-20, bottom:0 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#111122"/>
                    <XAxis dataKey="label" tick={{ fill:"#555577", fontSize:10 }} axisLine={false} tickLine={false}/>
                    <YAxis tick={{ fill:"#555577", fontSize:10 }} axisLine={false} tickLine={false}/>
                    <Tooltip {...ttStyle}/>
                    <Legend wrapperStyle={{ fontSize:10, fontFamily:"'DM Mono', monospace", color:"#8888aa" }}/>
                    <Bar dataKey="protein" fill="#3b82f6" radius={[3,3,0,0]}/>
                    <Bar dataKey="carbs" fill="#8b5cf6" radius={[3,3,0,0]}/>
                    <Bar dataKey="fat" fill="#f59e0b" radius={[3,3,0,0]}/>
                  </BarChart>
                </ResponsiveContainer>
              </div>

              <div style={S.section}>
                <div style={S.secTitle}>Calories — Last 7 Days</div>
                <ResponsiveContainer width="100%" height={160}>
                  <BarChart data={last7} margin={{ top:4, right:4, left:-20, bottom:0 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#111122"/>
                    <XAxis dataKey="label" tick={{ fill:"#555577", fontSize:10 }} axisLine={false} tickLine={false}/>
                    <YAxis tick={{ fill:"#555577", fontSize:10 }} axisLine={false} tickLine={false}/>
                    <Tooltip {...ttStyle}/>
                    <Bar dataKey="calories" fill="#2563eb" radius={[4,4,0,0]}/>
                  </BarChart>
                </ResponsiveContainer>
                {profile.goalCalories > 0 && (
                  <div style={{ fontSize:11, color:"#555577", textAlign:"right", marginTop:6 }}>
                    Goal: {profile.goalCalories} kcal/day
                  </div>
                )}
              </div>

              <div style={S.section}>
                <div style={S.secTitle}>Weight — Last 7 Days</div>
                <ResponsiveContainer width="100%" height={160}>
                  <LineChart data={last7} margin={{ top:4, right:4, left:-20, bottom:0 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#111122"/>
                    <XAxis dataKey="label" tick={{ fill:"#555577", fontSize:10 }} axisLine={false} tickLine={false}/>
                    <YAxis tick={{ fill:"#555577", fontSize:10 }} axisLine={false} tickLine={false} domain={["auto","auto"]}/>
                    <Tooltip {...ttStyle}/>
                    <Line type="monotone" dataKey="weight" stroke="#60a5fa" strokeWidth={2}
                      dot={{ fill:"#60a5fa", r:4 }} activeDot={{ r:6 }} connectNulls={false}/>
                  </LineChart>
                </ResponsiveContainer>
              </div>

              <div style={S.section}>
                <div style={S.secTitle}>7-Day Averages</div>
                {(() => {
                  const filled = last7.filter(d => d.calories > 0);
                  if (!filled.length) return <div style={{ color:"#333355", fontSize:12 }}>Log some days to see averages</div>;
                  const avg = (key) => Math.round(filled.reduce((a,d) => a + (d[key]||0), 0) / filled.length);
                  return (
                    <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
                      {[["Avg Calories",avg("calories"),"kcal","#60a5fa"],
                        ["Avg Protein",avg("protein"),"g","#3b82f6"],
                        ["Avg Carbs",avg("carbs"),"g","#8b5cf6"],
                        ["Avg Fat",avg("fat"),"g","#f59e0b"]
                      ].map(([label,val,unit,color]) => (
                        <div key={label} style={{ display:"flex", justifyContent:"space-between" }}>
                          <span style={{ fontSize:12, color:"#8888aa" }}>{label}</span>
                          <span style={{ fontSize:12, color }}>{val} {unit}</span>
                        </div>
                      ))}
                    </div>
                  );
                })()}
              </div>
            </div>
          )}

          {/* Nav */}
          <nav style={S.nav}>
            {TABS.map(t => {
              const Icon = NAV_ICONS[t];
              return (
                <button key={t} style={S.navBtn(tab === t)} onClick={() => setTab(t)}>
                  <Icon/>{t.toUpperCase()}
                </button>
              );
            })}
          </nav>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById("root"));
    root.render(React.createElement(Nutra));
  </script>
</body>
</html>
